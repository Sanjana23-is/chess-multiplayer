generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Game {
  id          String      @id @default(uuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  status      GameStatus
  whitePlayer String?
  blackPlayer String?
  result      String?
  winner      String?
  whiteTime   Int         @default(600000)
  blackTime   Int         @default(600000)
  moves       Move[]
}

model Move {
  id        String   @id @default(uuid())
  gameId    String
  from      String
  to        String
  promotion String?   // optional
  fen       String
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id])
}
enum GameStatus {
  WAITING
  ACTIVE
  FINISHED
}